# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/mentormatch

# Email Configuration
RESEND_API_KEY=your_resend_api_key_here
FROM_EMAIL=noreply@yourdomain.com

# Google OAuth Sign-In (for "Sign in with Google" button on the frontend)
GOOGLE_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com

# Google Meet Link Generation (creates real meet.google.com links)
# Run: npx tsx scripts/get-google-token.ts  to get the refresh token
GOOGLE_OAUTH_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your_google_oauth_client_secret
GOOGLE_OAUTH_REFRESH_TOKEN=your_refresh_token_from_script

# Google Calendar ID (optional, defaults to 'primary')
# GOOGLE_CALENDAR_ID=primary

# Session Configuration
SESSION_SECRET=your_session_secret_here

# Server Configuration
PORT=5000
NODE_ENV=development